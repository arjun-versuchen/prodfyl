# InterviewMaster AI — Environment Variables
# Copy to .env.development, .env.staging, or .env.production (never commit real secrets)

# App
VITE_APP_ENV=development
VITE_SITE_URL=http://localhost:5173

# Firebase (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Analytics (optional)
VITE_GA_ID=
VITE_CLARITY_ID=

# Razorpay public key is returned by createRazorpayOrder — no frontend Razorpay secret required

# Firebase Cloud Functions secrets (Firebase Secret Manager — NOT in frontend env)
# firebase functions:secrets:set RAZORPAY_KEY_ID
# firebase functions:secrets:set RAZORPAY_KEY_SECRET
# firebase functions:secrets:set RAZORPAY_WEBHOOK_SECRET
