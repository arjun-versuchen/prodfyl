# InterviewMaster AI — Environment Variables
# Copy to .env.development, .env.staging, or .env.production (never commit real secrets)

# App
VITE_APP_ENV=development
VITE_SITE_URL=http://localhost:5173

# Firebase (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Analytics (optional)
VITE_GA_ID=
VITE_CLARITY_ID=

# Razorpay (public key only on frontend)
VITE_RAZORPAY_KEY_ID=

# Firebase Cloud Functions secrets (set via Firebase CLI — not in frontend env)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
